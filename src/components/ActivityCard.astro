---
import type { Activity } from "~/lib/microcms";

type Props = {
  activity: Activity;
  eager?: boolean;
};

const { activity, eager = false } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = `${base}/activities/${activity.id}/`;

const dateLabel = new Date(activity.date).toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const imageSrc = `${activity.mainImage.url}?w=800&fm=webp`;
---

<article class="activity-card">
  <a class="activity-card__link" href={href}>
    <div class="activity-card__image-wrap">
      <img
        src={imageSrc}
        width="800"
        height={Math.round((activity.mainImage.height / activity.mainImage.width) * 800)}
        alt={activity.title}
        loading={eager ? "eager" : "lazy"}
        decoding="async"
      />
    </div>
    <div class="activity-card__body">
      <time class="activity-card__date" datetime={activity.date}>{dateLabel}</time>
      <h3 class="activity-card__title">{activity.title}</h3>
      <p class="activity-card__summary">{activity.summary}</p>
      <span class="activity-card__more" aria-hidden="true">活動を見る →</span>
    </div>
  </a>
</article>

<style>
  .activity-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .activity-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px var(--color-shadow);
  }
  .activity-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .activity-card__image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-accent-soft);
  }
  .activity-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .activity-card:hover .activity-card__image-wrap img {
    transform: scale(1.04);
  }
  .activity-card__body {
    padding: var(--space-5);
  }
  .activity-card__date {
    color: var(--color-muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }
  .activity-card__title {
    font-size: 1.15rem;
    margin: var(--space-2) 0 var(--space-3);
  }
  .activity-card__summary {
    color: var(--color-text);
    margin: 0 0 var(--space-3);
    font-size: 0.95rem;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .activity-card__more {
    color: var(--color-accent-strong);
    font-weight: 600;
    font-size: 0.95rem;
  }
</style>
