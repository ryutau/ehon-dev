---
type Props = {
  url?: string;
  heading?: string;
  body?: string;
  buttonLabel?: string;
};

const {
  url = "https://www.instagram.com/",
  heading = "最新情報はInstagramへ",
  body = "毎週の読み聞かせや、地域でのちいさなお知らせは Instagram で発信しています。",
  buttonLabel = "Instagramで活動を見る",
} = Astro.props;
---

<section class="instagram-cta">
  <div class="container instagram-cta__inner">
    <div>
      <p class="instagram-cta__eyebrow">Instagram</p>
      <h2 class="instagram-cta__heading">{heading}</h2>
      <p class="instagram-cta__body">{body}</p>
    </div>
    <a
      class="button instagram-cta__button"
      href={url}
      target="_blank"
      rel="noopener noreferrer"
    >
      <span aria-hidden="true">📷</span>
      <span>{buttonLabel}</span>
    </a>
  </div>
</section>

<style>
  .instagram-cta {
    padding-block: var(--space-7);
  }
  .instagram-cta__inner {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-7);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-5);
    align-items: center;
    box-shadow: 0 12px 30px var(--color-shadow);
  }
  .instagram-cta__eyebrow {
    color: var(--color-accent-strong);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    margin: 0 0 var(--space-2);
  }
  .instagram-cta__heading {
    margin: 0 0 var(--space-3);
    font-size: clamp(1.3rem, 3vw, 1.8rem);
  }
  .instagram-cta__body {
    margin: 0;
    color: var(--color-muted);
    max-width: 32em;
  }
  .instagram-cta__button {
    white-space: nowrap;
  }
  @media (max-width: 720px) {
    .instagram-cta__inner {
      grid-template-columns: 1fr;
      padding: var(--space-6);
    }
    .instagram-cta__button {
      justify-self: stretch;
    }
  }
</style>
