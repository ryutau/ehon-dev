---
import type { BookEntry } from "~/data/bookstart";

type Props = {
  books: BookEntry[];
  imageDir: string; // 例: "/images/bookstart-current"
};

const { books, imageDir } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const imageBase = `${base}${imageDir.startsWith("/") ? "" : "/"}${imageDir}`.replace(/\/$/, "");
---

<ol class="books">
  {books.map((book) => (
    <li class="book" id={`book-${book.no}`}>
      <div class="book__cover">
        {book.cover ? (
          <img
            src={`${imageBase}/${book.cover}`}
            alt={book.title}
            loading="lazy"
            decoding="async"
            width="160"
            height="220"
          />
        ) : (
          <div class="book__placeholder" aria-hidden="true">
            <span>{book.no}</span>
          </div>
        )}
      </div>
      <div class="book__body">
        <h3 class="book__title">
          <span class="book__no">{book.no}.</span>
          {book.title}
        </h3>
        {(book.author || book.publisher) && (
          <p class="book__meta">
            {book.author && <span>作・絵：{book.author}</span>}
            {book.author && book.publisher && <span class="book__sep">／</span>}
            {book.publisher && <span>{book.publisher}</span>}
          </p>
        )}
        <p class="book__comment">{book.comment}</p>
      </div>
    </li>
  ))}
</ol>

<style>
  .books {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }
  .book {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-5);
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }
  .book:last-child {
    border-bottom: none;
  }
  .book__cover {
    width: 160px;
    aspect-ratio: 4 / 5;
    background: var(--color-accent-soft);
    border-radius: var(--radius-sm);
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .book__cover img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--color-surface);
  }
  .book__placeholder {
    color: var(--color-accent-strong);
    font-size: 2.4rem;
    font-weight: 700;
  }
  .book__body {
    min-width: 0;
  }
  .book__title {
    margin: 0 0 var(--space-2);
    font-size: 1.1rem;
  }
  .book__no {
    color: var(--color-accent-strong);
    margin-right: var(--space-2);
  }
  .book__meta {
    margin: 0 0 var(--space-3);
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .book__sep {
    margin: 0 var(--space-1);
  }
  .book__comment {
    margin: 0;
    line-height: 1.85;
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .book {
      grid-template-columns: 100px 1fr;
      gap: var(--space-4);
    }
    .book__cover {
      width: 100px;
    }
  }
</style>
