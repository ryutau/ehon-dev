---
type Props = {
  imageSrc?: string;
  imageAlt?: string;
};

const {
  imageSrc,
  imageAlt = "えほんの森の活動の様子",
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="hero__eyebrow">絵本と人がつながる場所</p>
      <h1 class="hero__title">
        ゆっくり、<br />
        えほんとあそぼう。
      </h1>
      <p class="hero__lead">
        えほんの森は、地域で読み聞かせや親子のつどいを開く小さな活動です。
        子どもも大人も、好きな絵本のページをめくる時間をいっしょに過ごします。
      </p>
    </div>
    <div class="hero__image">
      {imageSrc ? (
        <img src={imageSrc} alt={imageAlt} width="1200" height="900" />
      ) : (
        <div class="hero__placeholder" aria-hidden="true">
          <span>📚</span>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(180deg, var(--color-accent-soft) 0%, var(--color-bg) 100%);
    padding-block: var(--space-8);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  .hero__eyebrow {
    color: var(--color-accent-strong);
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0 0 var(--space-3);
    letter-spacing: 0.08em;
  }
  .hero__title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: var(--space-5);
    letter-spacing: 0.02em;
  }
  .hero__lead {
    font-size: 1.05rem;
    color: var(--color-text);
    max-width: 32em;
  }
  .hero__image img,
  .hero__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 50px var(--color-shadow);
  }
  .hero__placeholder {
    background: var(--color-accent-soft);
    display: grid;
    place-items: center;
    font-size: 4rem;
  }
  @media (max-width: 720px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
