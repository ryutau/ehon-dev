---
import BaseLayout from "~/layouts/BaseLayout.astro";
import BookstartList from "~/components/BookstartList.astro";
import { oldBookstartBooks } from "~/data/bookstart";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title="はじめて絵本におすすめの30冊（旧バージョン）"
  description="旧バージョン（2021・2022・2023年度）のNPOブックスタート選書に合わせて、短いコメントを添えてご紹介する はじめての絵本におすすめの30冊です。"
>
  <section class="hero">
    <div class="container">
      <p class="hero__eyebrow">はじめて絵本におすすめの</p>
      <h1 class="hero__title">30冊（旧バージョン）</h1>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <h2 class="lede">絵本の紹介</h2>
      <p>
        こちらのNPOブックスタートの選書を2021・2022・2023年度版で実施した際の30冊です。
      </p>
      <p>
        <a class="button button--ghost" href={`${base}/bookstart/`}>
          現在版（2024・2025・2026年度）はこちら
        </a>
      </p>

      <BookstartList books={oldBookstartBooks} imageDir="/images/bookstart-old" />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(180deg, var(--color-accent) 0%, var(--color-accent-strong) 100%);
    color: #fff;
    padding-block: var(--space-7);
    text-align: center;
  }
  .hero__eyebrow {
    margin: 0 0 var(--space-2);
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    opacity: 0.92;
  }
  .hero__title {
    margin: 0;
    font-size: clamp(1.6rem, 5vw, 2.4rem);
  }
  .narrow {
    max-width: 760px;
  }
  .lede {
    font-size: 1.3rem;
    border-left: 4px solid var(--color-accent);
    padding-left: var(--space-3);
    margin-bottom: var(--space-4);
  }
</style>
